# ─── Backend Environment Variables ────────────────────────────────────────
# Copy this file to backend/.env for local development

# PostgreSQL (Neon)
DATABASE_URL=postgresql+asyncpg://user:password@ep-xxx.us-east-1.aws.neon.tech/sarvam_bot?sslmode=require

# AI API Keys
OPENAI_API_KEY=sk-...
SARVAM_API_KEY=...
GROQ_API_KEY=gsk_...

# WebRTC TURN Server
TURN_URL=turn:your-turn-server.com:3478
TURN_USERNAME=your-turn-username
TURN_CREDENTIAL=your-turn-credential

# App
APP_ENV=development
SECRET_KEY=change-this-to-a-secure-random-string-in-production

# ─── Frontend Environment Variables ───────────────────────────────────────
# Copy these to frontend/.env.local for local development

NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000
